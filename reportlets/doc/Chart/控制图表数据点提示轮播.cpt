<CellElementList>
<C c="0" r="0" s="0">
<O>
<![CDATA[开启数据点提示轮播]]></O>
<PrivilegeControl/>
<NameJavaScriptGroup>
<NameJavaScript name="JavaScript脚本1">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[//获取图表对象
var vanchart =FR.Chart.WebUtils.getChart("A3").getChartWithIndex(0);
// 开启数据提示轮播, 并将轮播控制器绑定到图表对象上
vanchart.controller = vanchart.openAutoTooltip();]]></Content>
</JavaScript>
</NameJavaScript>
</NameJavaScriptGroup>
<Expand/>
</C>
<C c="1" r="0" s="0">
<O>
<![CDATA[停止数据点提示轮播]]></O>
<PrivilegeControl/>
<NameJavaScriptGroup>
<NameJavaScript name="JavaScript脚本1">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[//获取图表对象
var vanchart =FR.Chart.WebUtils.getChart("A3").getChartWithIndex(0);
// 停止自动轮循播放数据点提示
vanchart.controller.stop(); ]]></Content>
</JavaScript>
</NameJavaScript>
</NameJavaScriptGroup>
<Expand/>
</C>
<C c="2" r="0" s="0">
<O>
<![CDATA[继续数据点提示轮播]]></O>
<PrivilegeControl/>
<NameJavaScriptGroup>
<NameJavaScript name="JavaScript脚本1">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[//获取图表对象
var vanchart =FR.Chart.WebUtils.getChart("A3").getChartWithIndex(0);
//继续从停止位置播放数据点提示轮播
vanchart.controller.moveOn(); ]]></Content>
</JavaScript>
</NameJavaScript>
</NameJavaScriptGroup>
<Expand/>
</C>
