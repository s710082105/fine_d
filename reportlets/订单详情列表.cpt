</Parameter>
<Parameter>
<Attributes name="end_date"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[qzcs]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
  od.id AS 明细ID,
  od.order_no AS 主订单号,
  od.ticket_no AS 票号,
  od.p_name AS 票品名称,
  od.pt_name AS 出票类型,
  od.price AS 实际单价,
  CASE od.status WHEN 0 THEN '待支付' WHEN 1 THEN '已支付' WHEN 3 THEN '已完成' WHEN 4 THEN '已关闭' ELSE CONCAT('未知(', od.status, ')') END AS 订单状态,
  CASE od.is_pay WHEN 0 THEN '待支付' WHEN 1 THEN '已支付' ELSE CONCAT('未知(', od.is_pay, ')') END AS 支付状态,
  CASE od.is_refund WHEN 0 THEN '无退款' WHEN 2 THEN '完全退款' ELSE CONCAT('未知(', od.is_refund, ')') END AS 退款状态,
  CASE od.is_print WHEN 0 THEN '未出票' WHEN 2 THEN '已出票' ELSE CONCAT('未知(', od.is_print, ')') END AS 出票状态,
  CASE od.is_check WHEN 0 THEN '未验票' WHEN 2 THEN '已验票' ELSE CONCAT('未知(', od.is_check, ')') END AS 验票状态,
  COALESCE(od.name, '') AS 姓名,
  COALESCE(od.phone, '') AS 手机号,
  COALESCE(od.id_card, '') AS 身份证,
  DATE_FORMAT(od.start, '%Y-%m-%d %H:%i:%s') AS 开始时间,
  DATE_FORMAT(od.end, '%Y-%m-%d %H:%i:%s') AS 结束时间,
  DATE_FORMAT(od.paid_at, '%Y-%m-%d %H:%i:%s') AS 支付时间,
  DATE_FORMAT(od.created_at, '%Y-%m-%d %H:%i:%s') AS 创建时间
FROM t_order_details od
WHERE 1 = 1
${if(len(order_no) == 0, "", " AND od.order_no LIKE '%" + order_no + "%'")}
${if(len(ticket_no) == 0, "", " AND od.ticket_no LIKE '%" + ticket_no + "%'")}
${if(len(status) == 0, "", " AND od.status = " + status)}
${if(len(phone) == 0, "", " AND od.phone LIKE '%" + phone + "%'")}
${if(len(start_date) == 0, "", " AND od.created_at >= '" + start_date + "'")}
${if(len(end_date) == 0, "", " AND od.created_at <= '" + end_date + " 23:59:59'")}
ORDER BY od.created_at DESC]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
</TableDataMap>
