<?xml version="1.0" encoding="UTF-8"?>
<WorkBook xmlVersion="20211223" releaseVersion="11.5.0">
<TableDataMap>
<TableData name="ds_order_details" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="order_no"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="ticket_no"/>
